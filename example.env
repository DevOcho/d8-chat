# D8-Chat Environment Variables
# Copy this file to .env and fill in the values.

# --- Application Settings ---
# Generate a long (32+ chars), random string for this. Required.
# You can use: python -c 'import secrets; print(secrets.token_urlsafe(48))'
SECRET_KEY=changeme_must_be_at_least_32_characters_long

# --- Public Hostname ---
# The domain name or IP address where this service will be accessible.
# For local testing, 'localhost' is fine. For a server, use 'd8-chat.yourdomain.com' or your server's IP.
D8CHAT_HOSTNAME=localhost

# --- Let's Encrypt SSL Settings ---
# The email address to use for Let's Encrypt registration and notifications.
CERTBOT_EMAIL=changeme@youremail.com

# --- PostgreSQL Database Connection ---
# These must match the values in the 'db' service in docker-compose.yaml
POSTGRES_USER=d8chat_user
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=d8chat_db

# This is the full connection string the Flask app uses.
# The hostname 'db' matches the service name in docker-compose.yaml.
# Note: Only change this if you plan to use a cloud hosted version instead of
# the dockerized version of postgres
DATABASE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Minio S3 Storage Connection ---
# These must match the values in the 'minio' service in docker-compose.yaml
MINIO_ROOT_USER=minio-d8
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET_NAME=d8chat

# This is the internal endpoint for the app to talk to Minio.
# The hostname 'minio' matches the service name in docker-compose.yaml.
MINIO_ENDPOINT=minio:9000
# This is the public-facing URL for generating links for users.
# For local development, this points to your host machine.
MINIO_PUBLIC_URL=http://${D8CHAT_HOSTNAME}:9000
MINIO_SECURE=False

# Valkey (Redis fork) settings
VALKEY_URL=redis://valkey:6379/0

# --- Internal Service-to-Service Auth ---
# Shared secret for POST /api/v1/internal/notify. Internal callers (e.g. the
# helpdesk service) send this value in the X-Internal-Key header. Generate a
# random 32+ char value and store the same string on both ends.
# INTERNAL_NOTIFY_KEY=changeme_internal_notify_shared_secret

# --- OIDC/SSO Settings (Optional) ---
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER_URL=
